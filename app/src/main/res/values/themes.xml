<resources>

    <style name="Base.Theme.Baskit" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary actions = evergreen -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorPrimaryContainer">@color/primary_variant</item>

        <!-- Secondary accents = warm caramel -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorSecondaryContainer">@color/surface</item>

        <!-- Navigation + icons = evergreen and warm neutrals -->
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Background & surfaces -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnBackground">@color/on_background</item>

        <!-- Destructive actions -->
        <item name="colorError">@color/destructive</item>

        <!-- Outline, borders, dividers -->
        <item name="colorOutline">#14000000</item>

        <!-- Accents -->
        <item name="colorTertiary">@color/destructive</item>

        <item name="android:colorBackground">@color/background</item>
        <item name="backgroundColor">@color/background</item>
        <item name="colorOnContainerUnchecked">@color/unchecked</item>

    </style>

    <style name="Theme.Baskit" parent="Base.Theme.Baskit" />

</resources>