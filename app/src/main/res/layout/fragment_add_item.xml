<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:gravity="center_vertical|start"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <ImageButton
                android:id="@+id/btn_cancel"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@null"
                android:backgroundTint="?attr/colorSecondary"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_cancel"
                android:contentDescription="@string/action_cancel" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:visibility="invisible" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="15dp"
        android:layout_weight="1"
        android:gravity="center_horizontal|top"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginBottom="20dp"
            android:elevation="6dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp">

            <AutoCompleteTextView
                android:id="@+id/searchItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginVertical="10dp"
                android:background="@null"
                android:clickable="true"
                android:completionThreshold="1"
                android:dropDownHeight="200dp"
                android:dropDownVerticalOffset="5dp"
                android:ellipsize="none"
                android:focusable="true"
                android:gravity="start"
                android:hint="@string/item_search"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:scrollHorizontally="false"
                android:singleLine="true"
                android:textColor="?attr/colorPrimaryVariant"
                android:textColorHighlight="?attr/colorSecondaryVariant"
                android:textColorHint="?attr/colorPrimaryVariant"
                android:textSize="28sp" />

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/lout_info"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_horizontal|top"
            android:orientation="vertical"
            android:visibility="visible"
            tools:ignore="NestedWeights">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp"
                android:elevation="6dp"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical|start"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/item_quantity"
                        android:textColor="?attr/colorSecondary"
                        android:textSize="30sp" />

                    <Space
                        android:layout_width="5dp"
                        android:layout_height="match_parent"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageButton
                            android:id="@+id/btn_up"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_arrow_up"
                            app:tint="?attr/colorSecondary"
                            android:contentDescription="@string/item_increase_quantity" />

                        <TextView
                            android:id="@+id/tv_quantity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/colorSecondary"
                            android:textSize="28sp" />

                        <ImageButton
                            android:id="@+id/btn_down"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="?attr/colorSecondary"
                            android:contentDescription="@string/item_decrease_quantity" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="10dp"
                tools:ignore="NestedWeights">

                <!-- Variation Filter (Weight / Unit Chips) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:orientation="vertical">

                    <!-- Weights -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chip_group_weights"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:chipSpacingHorizontal="8dp"
                            app:selectionRequired="false"
                            app:singleLine="true"
                            app:singleSelection="false" />

                    </HorizontalScrollView>

                    <!-- Units -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chip_group_units"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:chipSpacingHorizontal="8dp"
                            app:selectionRequired="false"
                            app:singleLine="true"
                            app:singleSelection="false" />

                    </HorizontalScrollView>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="@string/supermarket_available"
                    android:textColor="?attr/colorPrimaryVariant"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <include
                    layout="@layout/supermarkets_list"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="10dp"
                    android:layout_weight="1"
                    android:padding="8dp"
                    tools:ignore="NestedWeights" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="?attr/colorPrimaryVariant"
            android:elevation="8dp"
            android:text="@string/action_add"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="40sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:iconPadding="8dp"
            app:rippleColor="?attr/colorOnPrimary" />

    </LinearLayout>

</LinearLayout>