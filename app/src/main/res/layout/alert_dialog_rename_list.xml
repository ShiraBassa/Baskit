<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/backgroundColor"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingHorizontal="22dp"
    android:paddingTop="20dp"
    android:paddingBottom="16dp"
    android:orientation="vertical"
    tools:ignore="Overdraw">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="10dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="0.7dp">

            <ImageButton
                android:id="@+id/btn_cancel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:contentDescription="@string/action_cancel"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_cancel"
                app:tint="?attr/colorOnSurface" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0"
            android:text="@string/list_change_name"
            android:textColor="?attr/colorOnSurface"
            android:textSize="24sp"
            android:textStyle="normal"
            android:labelFor="@+id/et_name" />

    </LinearLayout>

    <EditText
        android:id="@+id/et_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:autofillHints=""
        android:background="@drawable/bg_selectable_surface"
        android:fontFamily="sans-serif-medium"
        android:hint="@string/list_change_name"
        android:inputType="textPersonName"
        android:minHeight="58dp"
        android:paddingHorizontal="18dp"
        android:paddingVertical="14dp"
        android:singleLine="true"
        android:textColor="?attr/colorOnSurface"
        android:textColorHint="?attr/colorOutline"
        android:textSize="18sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save_name"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="?attr/colorPrimary"
        android:elevation="0dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/action_save"
        android:textAllCaps="false"
        android:textColor="?attr/colorOnPrimary"
        android:textSize="17sp"
        android:textStyle="normal"
        app:cornerRadius="20dp"
        app:rippleColor="?attr/colorOnPrimary" />

</LinearLayout>