<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColor"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:gravity="top|start"
    android:paddingHorizontal="20dp"
    android:paddingTop="18dp"
    android:paddingBottom="14dp"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:gravity="center_vertical|start"
        android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="0.7dp">

            <ImageButton
                android:id="@+id/btn_cancel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:contentDescription="@string/action_cancel"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_cancel"
                app:tint="?attr/colorOnSurface" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="15dp"
        android:layout_weight="1"
        android:gravity="center_horizontal|top"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_item_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0"
            android:textColor="?attr/colorOnSurface"
            android:textSize="30sp"
            android:textStyle="normal" />

        <LinearLayout
            android:id="@+id/lout_quantity_whole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical|start"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/item_quantity"
                android:textColor="?attr/colorOnSurface"
                android:textSize="20sp" />

            <LinearLayout
                android:id="@+id/lout_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:paddingVertical="12dp">

                <ImageButton
                    android:id="@+id/btn_up"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@android:color/transparent"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_arrow_up"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="@string/item_increase_quantity" />

                <TextView
                    android:id="@+id/tv_quantity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="22sp" />

                <ImageButton
                    android:id="@+id/btn_down"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@android:color/transparent"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="@string/item_decrease_quantity" />

            </LinearLayout>

        </LinearLayout>

        <!-- Variation Filter (Weight / Unit Chips) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Weights -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_weights"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="8dp"
                    app:selectionRequired="false"
                    app:singleLine="true"
                    app:singleSelection="false" />

            </HorizontalScrollView>

            <!-- Units / Companies -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_units"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="8dp"
                    app:selectionRequired="false"
                    app:singleLine="true"
                    app:singleSelection="false" />

            </HorizontalScrollView>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            tools:ignore="NestedWeights">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="14dp"
                android:letterSpacing="0"
                android:text="@string/supermarket_available"
                android:textColor="?attr/colorOnSurface"
                android:textSize="24sp"
                android:textStyle="normal" />

            <include
                layout="@layout/supermarkets_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                tools:ignore="NestedWeights" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="6dp"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:backgroundTint="?attr/colorPrimary"
            android:elevation="0dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/action_save"
            android:textAllCaps="false"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="18sp"
            android:textStyle="normal"
            app:cornerRadius="22dp"
            app:rippleColor="?attr/colorOnPrimary" />

    </LinearLayout>
</LinearLayout>