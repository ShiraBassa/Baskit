<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:gravity="center"
    android:orientation="vertical"
    tools:context=".Firebase.SignUpActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="讘专讜讱 讛讘讗 诇\nBaskit馃洅"
        android:textStyle="bold"
        android:layout_marginBottom="15dp"
        android:textSize="42sp"
        android:textColor="?attr/colorPrimary"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="讗谞讗 讛讻谞住 讗转 驻专讟讬讱 讘砖讚讜转 讛谞状诇"
        android:layout_marginBottom="15dp"
        android:textColor="?attr/colorSecondary"
        android:textSize="26sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end|center_vertical"
        android:layout_margin="10dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/et_username"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="100dp"
            android:textColor="?attr/colorSecondary"
            android:singleLine="true"
            android:layoutDirection="rtl"
            android:textDirection="rtl"
            android:maxLength="20"
            android:inputType="text"
            android:backgroundTint="?attr/colorPrimary"
            android:textCursorDrawable="@null"
            android:textColorHighlight="?attr/colorPrimary"
            android:digits=" 讗讘讙讚讛讜讝讞讟讬讻诇诪谞住注驻爪拽专砖转讱诐谉祝抓"
            android:textSize="28sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="砖诐 诪砖转诪砖:"
            android:textColor="?attr/colorPrimary"
            android:textSize="28sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="20dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include
                android:id="@+id/cities_table"
                layout="@layout/cities_table" />

            <include
                android:id="@+id/supermarkets_table"
                layout="@layout/supermarkets_table" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/btn_submit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="讘讜爪注"
        android:textSize="32sp" />

</LinearLayout>